# Copy this file to ".env" for local development and fill real values.
# On your host (Render/PythonAnywhere), set these as environment variables instead.

# Generate a new one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-with-a-long-random-secret

# Use False in production
DEBUG=True

# Comma-separated. Add your host domain, e.g. myapp.onrender.com or username.pythonanywhere.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated frontend origins allowed to call this API
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
